PORT=3000
CORS_ORIGIN="http://localhost:4200"

# Database configuration
DB_URL = "postgresql://admin:admin123@localhost:5432/name"
DB_NAME = "name"
DB_USER = "user"
DB_PASSWORD = "user123"
DB_HOST = "localhost"
DB_PORT = 5432

# JWT configuration
JWT_SECRET = "some_random_secret_key"
JWT_EXPIRES_IN = 86400 # 24 hours in seconds

# Cookie configuration
COOKIE_NAME = "auth"
COOKIE_MAX_AGE = 3600000 # 1 hour in milliseconds
COOKIE_SECURE = false
COOKIE_HTTP_ONLY = true